generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom fields
  githubUsername String?   @unique
  analysisResult AnalysisResult?
  
  // Privacy & Discovery
  isPublicProfile Boolean  @default(true)
  allowSeoIndexing Boolean @default(true)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnalysisResult {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // High-level aggregates
  overallScore     Int
  archetype        Json?    // { name: string, description: string, idealEnvironment: string }
  summary          String   @db.Text
  narrative        String?  @db.Text // "Holy shit, this platform actually understands..." narrative
  
  // Specific technical scoring
  frontendScore    Int
  backendScore     Int
  devopsScore      Int
  architectureScore Int
  
  // Deep AI Insights
  developerDna     Json?    // { technicalTraits: string[], workflowHabits: string[], strengths: string[], weaknesses: string[] }
  evolutionTimeline Json?   // [{ year: number, phase: string, description: string }]
  projectIntelligence Json? // [{ repoName: string, architectureNotes: string, scalability: string, score: number }]
  careerIntelligence Json?  // { startupFit: number, enterpriseFit: number, roleRecommendations: string[], hiringSignals: string[] }
  
  rawGithubData    Json?    // Optional storage for raw fetched data
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
